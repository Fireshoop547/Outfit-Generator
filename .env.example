# Outfit Generator — API Keys
# Copy this file to .env and fill in your actual API keys
# .env is in .gitignore and will NOT be committed

# Get free RapidAPI key from: https://rapidapi.com/h-m-hennes-mauritz.p.rapidapi.com
# Search for "H&M" or "Hennes & Mauritz" on RapidAPI
RAPIDAPI_KEY=your_rapidapi_key_here

# Get free ScraperAPI key from: https://www.scraperapi.com/
# Used as fallback scraper (optional, needed only for quick_fetch.py)
SCRAPERAPI_KEY=your_scraperapi_key_here
